# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Application URL — use https://lang-hub.netlify.app on Netlify production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-side feature flags
# Netlify production: set PUBLIC_API_ENABLED=true to expose /api/v1/*.
PUBLIC_API_ENABLED=false
# Keep false until the Translation Memory branch is deployed and verified, then set true.
TRANSLATION_ASSISTANCE_ENABLED=false

# Locale catalog — required when the REST Countries API account enforces authentication
RESTCOUNTRIES_API_KEY=rc_live_...

# AI — KHÔNG dùng trong MVP, thêm khi làm Phase 8
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
